# Copy to .env and edit. Every value has a sane default — with no changes at all
# Caption Generation runs fully local (CPU transcription, LLM features off).

# Server
CAPTION_HOST=0.0.0.0
CAPTION_PORT=8000
# CAPTION_CORS_ORIGINS=http://localhost:5173   # the bundled UI is same-origin; usually unneeded
LOG_LEVEL=info

# Storage & limits
DATA_DIR=/data
MAX_UPLOAD_MB=51200          # ~50 GB; set 0 for no limit, or lower (MB) for a public instance
WORKER_CONCURRENCY=1          # transcription is heavy; raise only on a strong box
JOB_RETENTION_HOURS=72        # auto-delete jobs + files after N hours (0 = keep forever)

# Transcription engine: local (faster-whisper, no key) or openai (hosted Whisper API)
TRANSCRIBE_ENGINE=local

# When local:
WHISPER_MODEL=base            # tiny | base | small | medium | large-v3
WHISPER_DEVICE=auto           # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=auto     # auto | int8 | int8_float16 | float16 | float32

# When openai:
# TRANSCRIBE_API_BASE_URL=https://api.openai.com/v1
# TRANSCRIBE_API_KEY=sk-...
# TRANSCRIBE_API_MODEL=whisper-1

# LLM for chapters / summary / translation (optional — subtitles work without it).
# Leave LLM_BASE_URL empty to keep it off. Any OpenAI-compatible endpoint works:
#   Ollama (bundled):     LLM_BASE_URL=http://ollama:11434/v1   (docker compose --profile ollama up)
#   Ollama on this host:  LLM_BASE_URL=http://localhost:11434/v1  + host-network override (see README)
#   OpenAI:               LLM_BASE_URL=https://api.openai.com/v1  LLM_API_KEY=sk-...  LLM_MODEL=gpt-4o-mini
#   OpenRouter:           LLM_BASE_URL=https://openrouter.ai/api/v1  (put your key in LLM_API_KEY)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=llama3.1:8b
LLM_MAX_INPUT_TOKENS=12000

# Translation engine: auto | whisper | libretranslate | llm | off
#   auto (default): Whisper's translate task for →English; LibreTranslate if set
#                   below; otherwise the LLM. (Whisper can only output English.)
TRANSLATE_ENGINE=auto
# Optional dedicated offline translator — run: docker compose --profile translate up -d
# LIBRETRANSLATE_URL=http://libretranslate:5000   # bridge network
# LIBRETRANSLATE_URL=http://localhost:5000        # if the app uses host networking
# LIBRETRANSLATE_API_KEY=
